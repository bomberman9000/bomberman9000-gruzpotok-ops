# Скопируйте в .env:  Copy-Item .env.example .env

POSTGRES_USER=ollama_app
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=ollama_app
POSTGRES_PORT=5432

REDIS_PORT=6379
# В docker compose для rag-api по умолчанию: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# RAG API
RAG_PORT=8080
DATABASE_URL=postgresql://ollama_app:your_strong_password_here@localhost:5432/ollama_app

OLLAMA_BASE_URL=http://host.docker.internal:11434
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_MODEL=llama3:8b
OLLAMA_CHAT_MODEL=llama3:8b
# Контекст и (опционально) температура для /api/chat; см. ollama/README.md
OLLAMA_NUM_CTX=8192
# OLLAMA_TEMPERATURE=0.7

RAG_TOP_K=12
RAG_FINAL_K=6
RAG_MODE_DEFAULT=balanced

STRICT_MIN_RERANK_SCORE=0.22
STRICT_MAX_VECTOR_DISTANCE=0.55

RERANK_ALPHA=0.65
RERANK_BETA=0.25
RERANK_GAMMA=0.1

LOG_LEVEL=INFO
LOG_JSON=false

# Backend ГрузПотока (интеграция с rag-api), см. docs/AI_INTEGRATION.md
GRUZPOTOK_BACKEND_PORT=8090
RAG_API_BASE_URL=http://localhost:8080
RAG_API_TIMEOUT_SEC=120
RAG_API_ENABLED=true
RAG_API_DEBUG_DEFAULT=false
RAG_API_RETRY_COUNT=2

# AI Gateway Phase 1A (disabled by default; legacy path is unchanged)
AI_GATEWAY_ENABLED=false
AI_GATEWAY_PROVIDER=legacy
AI_GATEWAY_REMOTE_URL=
AI_GATEWAY_ALLOWED_REMOTE_PREFIXES=
AI_GATEWAY_TIMEOUT_SEC=30
AI_GATEWAY_INTERNAL_TOKEN=
AI_GATEWAY_CONNECT_TIMEOUT_SEC=3
AI_GATEWAY_READ_TIMEOUT_SEC=30
AI_GATEWAY_TOTAL_TIMEOUT_SEC=35
AI_GATEWAY_MAX_PAYLOAD_BYTES=262144
AI_GATEWAY_MAX_RESPONSE_BYTES=1048576

# Backend ГрузПотока: PostgreSQL для ai_calls / ai_feedback (тот же DSN, что у приложения)
BACKEND_DATABASE_URL=postgresql://ollama_app:your_strong_password_here@localhost:5432/ollama_app
