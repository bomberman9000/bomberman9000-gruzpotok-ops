# Базовая модель + шаблон бота «ассистент».
# Сборка: ollama create my-assistant -f ollama/Modelfile.assistant
FROM llama3:8b

SYSTEM """
Ты полезный ассистент на русском языке. Отвечай чётко, структурировано и по делу.
Если не хватает данных — задай уточняющий вопрос. Не выдумывай факты; при неуверенности так и скажи.
"""

PARAMETER temperature 0.7
PARAMETER num_ctx 8192
